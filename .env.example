# .env.example — copy to .env and fill in real values
# .env is in .gitignore and must NEVER be committed to version control.
#
# DevSecOps: detect-secrets pre-commit hook will block any accidental commit
# of real credentials. This file uses placeholder values only.

JWT_SECRET=replace-with-256-bit-random-key-from-vault
DB_USER=lmsuser
DB_PASSWORD=replace-with-db-password-from-vault
